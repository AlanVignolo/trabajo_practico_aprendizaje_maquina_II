# Copy this file to .env and fill in the values:  cp .env.example .env

# postgres configuration
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=mlflow_db
PG_PORT=5432

# mlflow configuration
MLFLOW_PORT=5001
MLFLOW_S3_ENDPOINT_URL=http://s3:9000
MLFLOW_DB=mlflow_db

# minio configuration
MINIO_PORT=9000
MINIO_PORT_UI=9001
MLFLOW_BUCKET_NAME=mlflow
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

# airflow database 
AIRFLOW_PG_DATABASE=airflow
AIRFLOW_PG_USER=airflow
AIRFLOW_PG_PASSWORD=airflow

# airflow runtime user
AIRFLOW_UID=50000
AIRFLOW_GID=0

# airflow web UI (http://localhost:${AIRFLOW_PORT}) — these create + login the Airflow console
AIRFLOW_PORT=8080
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
